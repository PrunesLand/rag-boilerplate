# Copy to .env and edit. .env is gitignored. Every value has a working default
# in config.py — you only need to set what you want to override.

# ── Identity ──────────────────────────────────────────────────────────────────
ORGANIZATION_NAME=Your Organization
# ASSISTANT_DESCRIPTION=a support assistant for Your Organization

# ── Providers ─────────────────────────────────────────────────────────────────
# LLM_PROVIDER: ollama | openai | anthropic
# EMBEDDING_PROVIDER: ollama | openai
# VECTORSTORE_PROVIDER: chroma | pgvector
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
VECTORSTORE_PROVIDER=chroma

# ── Models (names are provider-specific) ──────────────────────────────────────
LLM_MODEL=qwen2.5:0.5b-instruct
EMBEDDING_MODEL=nomic-embed-text
# LLM_TEMPERATURE=0.0

# ── Provider connections ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# PGVECTOR_CONNECTION=postgresql+psycopg://user:pass@localhost:5432/db

# ── Feature toggles ───────────────────────────────────────────────────────────
# USE_HYBRID_SEARCH=true
# USE_RERANKER=true
# USE_MULTI_QUERY=true
# USE_REVERSE_HYDE=true
# USE_CRAG=false            # turn on with a 7b+/cloud LLM

# ── Crawling ──────────────────────────────────────────────────────────────────
# CRAWL_MAX_DEPTH=1
# RESPECT_ROBOTS_TXT=true

# ── Optional: LangSmith tracing ───────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=org-rag

# Secrets only. Copy to .env and fill in whichever your chosen providers need.
# .env is gitignored — never commit real keys.
#
# Everything else — provider selection, model names, feature toggles, crawl
# behavior, etc. — is configured in config.py directly, not here.

# OpenAI (LLM_PROVIDER=openai and/or EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Anthropic (LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Postgres/pgvector (VECTORSTORE_PROVIDER=pgvector)
# PGVECTOR_CONNECTION=postgresql+psycopg://user:pass@localhost:5432/db

# LangSmith tracing (optional). These must be real environment variables —
# LangChain's SDK reads them directly from the process environment, not from
# config.py.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=org-rag
